<Window x:Class="CigarHouseApp.Views.AddBrandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CigarHouseApp.Views"
        mc:Ignorable="d"
        Title="AddBrandWindow" Height="400" Width="500">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource MediumBrown}" Padding="25,20">

            <StackPanel>
                <TextBlock Text="Добавить бренд" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextLight}"
                           FontFamily="B612 Mono"/>
            </StackPanel>
        </Border>

        <StackPanel x:Name="stBrand" Grid.Row="1">
            <StackPanel Margin="30,25,30,15">
                <StackPanel Margin="0,0,0,25" HorizontalAlignment="Center">
                </StackPanel>
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Название бренда" 
                               FontFamily="B612 Mono" 
                               FontSize="12" 
                               Foreground="{StaticResource MediumBrown}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="tbBrandName" 
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Телефон" 
                               FontFamily="B612 Mono" 
                               FontSize="12" 
                               Foreground="{StaticResource MediumBrown}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="tbPhone" 
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="{StaticResource BeigeMedium}"
                BorderThickness="0,1,0,0"
                Padding="25,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancelButton" 
                        Content="Отмена"
                        Style="{StaticResource BasicButton}"
                        Width="120"
                        Margin="0,0,15,0"
                        Click="btnCancelButton_Click"/>
                <Button x:Name="btnAddBrand" 
                        Content="Сохранить"
                        Style="{StaticResource BasicButton2}"
                        Width="120"
                        Click="btnAddBrand_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
