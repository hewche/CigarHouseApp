<Window x:Class="CigarHouseApp.Views.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
            xmlns:local="clr-namespace:CigarHouseApp.Views"
            mc:Ignorable="d"
            FontFamily="Exo 2 Extra Bold"
            Title="MainWindow" Height="650" Width="800" Loaded="Window_Loaded" Cursor="">

    <Grid Cursor="">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#1C1C1C" Offset="0.0"/>
                    <GradientStop Color="#2C1A07" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Height="60">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.7*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Background="Transparent">
                    <StackPanel Margin="20 0 0 0"  VerticalAlignment="Center">
                        <TextBlock Text="Каталог товаров" 
                                      Foreground="White"
                                      FontSize="16"
                                      FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
                <TabControl Grid.Column="1" 
                               Grid.ColumnSpan="5"
                               Background="Transparent" 
                               BorderThickness="0"
                               Height="60"
                            SelectedIndex="-1"
                            x:Name="tabControlProducts"
                            SelectionChanged="TabControl_SelectionChanged"
                            >

                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="BgBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="3"
                                                    Height="60"
                                                    Width="120">
                                            <ContentPresenter x:Name="ContentSite"
                                                                ContentSource="Header"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BgBorder" 
                                                            Property="Background" 
                                                            Value="#CE9E6E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                    </TabControl.Resources>

                    <TabControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </TabControl.ItemsPanel>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Vertical" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center">
                                <Image Source="/Images/cigar_icon.png" 
                                           Width="18" 
                                           Height="18"/>
                                <TextBlock Text="Сигары" 
                                              Foreground="White"
                                              FontSize="12"
                                              Margin="0,2,0,0"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>


                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Vertical" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center">
                                <Image Source="/Images/cigarillo_icon.png" 
                                           Width="18" 
                                           Height="18"/>
                                <TextBlock Text="Сигариллы" 
                                              Foreground="White"
                                              FontSize="12"
                                              Margin="0,2,0,0"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Background="#1E1E1E">
                            <TextBlock Text="Контент: Сигариллы" 
                                          Foreground="White" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontSize="18"/>
                        </Grid>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Vertical" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center">
                                <Image Source="/Images/lighter_icon.png" 
                                           Width="18" 
                                           Height="18"/>
                                <TextBlock  Text="Аксессуары" 
                                              Foreground="White"
                                              FontSize="12"
                                              Margin="0,2,0,0"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Vertical" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center">
                                <Image Source="/Images/sets_icon.png" 
                                           Width="18" 
                                           Height="18"/>
                                <TextBlock Text="Наборы" 
                                              Foreground="White"
                                              FontSize="12"
                                              Margin="0,2,0,0"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Vertical" 
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center">
                                <Image Source="/Images/ranking_icon.png" 
                                           Width="18" 
                                           Height="18"/>
                                <TextBlock Text="Лучшее" 
                                              Foreground="White"
                                              FontSize="12"
                                              Margin="0,2,0,0"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                </TabControl>

            </Grid>

        </Border>
        <StackPanel Height="150" Margin="15 10 15 0" Grid.Row="1" Visibility="Visible">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <ListBox Grid.Row="0" Grid.Column="0" Width="200" Height="30"></ListBox>
                <ListBox Grid.Row="0" Grid.Column="1" Width="200" Height="30"></ListBox>
                <TextBox Grid.Row="0" Grid.Column="2" Width="200" Height="30" BorderThickness="0 0 0 1" ></TextBox>

                <StackPanel  Grid.Row="1" Grid.Column="0" Height="60">
                    <TextBlock Margin="0 0 0 5" Text="Цена"></TextBlock>
                    <Slider Value="0" Minimum="0" Maximum="100" SelectionStart="0" IsSelectionRangeEnabled="True" ValueChanged="Slider_ValueChanged" />
                </StackPanel>

                <StackPanel  Margin="10 0 0 10" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Cursor="Hand" FontWeight="Bold" Foreground="#6b4e23" Text="Доп. фильтры"></TextBlock>
                </StackPanel>

                <StackPanel x:Name="additionFilters" Visibility="Hidden" Grid.Row="2" Grid.ColumnSpan="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top">
                            <TextBlock Text="Крепость"></TextBlock>
                            <ListBox Width="30" Height="10"></ListBox>
                        </StackPanel>

                        <StackPanel Margin="10 0 0 10" Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top">
                            <StackPanel  Orientation="Horizontal">
                                <TextBlock Text="Длина"></TextBlock>
                                <TextBox Width="20"></TextBox>
                                <TextBlock Text="-"></TextBlock>
                                <TextBox Width="20"></TextBox>
                            </StackPanel>
                            <Slider Value="0" Minimum="0" Maximum="100" SelectionStart="0"  IsSelectionRangeEnabled="True" ValueChanged="Slider_ValueChanged" />
                        </StackPanel>

                        <StackPanel  Margin="10 0 0 10" Grid.Column="2" Orientation="Vertical" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Толщина"></TextBlock>
                                <TextBox Width="20"></TextBox>
                                <TextBlock Text="-"></TextBlock>
                                <TextBox Width="20"></TextBox>
                            </StackPanel>
                            <Slider Value="0" Minimum="0" Maximum="100" SelectionStart="0"  Style="{StaticResource MaterialDesignDiscreteSlider}"   IsSelectionRangeEnabled="True" ValueChanged="Slider_ValueChanged"/>
                        </StackPanel>
                    </Grid>
                   
                </StackPanel>
                
            </Grid>
        </StackPanel>
        <Frame Grid.Row="2" x:Name="cigarFrame" JournalOwnership="OwnsJournal" NavigationUIVisibility="Hidden" HorizontalAlignment="Stretch" Focusable="False" IsTabStop="False"/>

        <Button Margin="0" Grid.RowSpan="5" Width="60" Height="60" BorderBrush="Transparent" VerticalAlignment="Bottom" HorizontalAlignment="Left" Background="Transparent" Cursor="Hand">
            <Image Source="/Images/profile_icon.png"></Image>
        </Button>
        <Button Margin="0" Grid.RowSpan="5" Width="60" Height="60" BorderBrush="Transparent" VerticalAlignment="Bottom" HorizontalAlignment="Right" Background="Transparent" Cursor="Hand">
            <Image Source="/Images/handbag.png"></Image>
        </Button>
    </Grid>

</Window>