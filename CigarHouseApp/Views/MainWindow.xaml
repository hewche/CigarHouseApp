<Window x:Class="CigarHouseApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Background="#F5F5F5"
        FontFamily="Segoe UI Semibold" 
        Title="Cigar House" Height="700" Width="950" Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="DeepBrown" Color="#4E342E"/>
        <SolidColorBrush x:Key="BeigeLight" Color="#D7CCC8"/>
        <SolidColorBrush x:Key="GoldAccent" Color="#CE9E6E"/>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="BgBorder"
                                Background="{StaticResource DeepBrown}"
                                CornerRadius="5"
                                Margin="4,5"
                                MinWidth="110"
                                Height="55">
                            <ContentPresenter x:Name="ContentSite"
                                            ContentSource="Header"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#6D4C41"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource BeigeLight}"/>
                                <Setter Property="Foreground" Value="{StaticResource DeepBrown}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Cursor="">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid Height="75">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="КАТАЛОГ" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{StaticResource DeepBrown}" FontSize="18" FontWeight="Black"/>

                <TabControl Grid.Column="1" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Loaded="tabControlProducts_Loaded"
                            x:Name="tabControlProducts"
                            SelectionChanged="TabControl_SelectionChanged">
                    <TabControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </TabControl.ItemsPanel>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/cigar_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="СИГАРЫ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>


                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/lighter_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="АКСЕССУАРЫ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/sets_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="НАБОРЫ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/ranking_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="ЛУЧШЕЕ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        

        <Frame Grid.Row="1" x:Name="cigarFrame" NavigationUIVisibility="Hidden"/>

        <Button Grid.Row="1" Width="50" Height="50" Margin="25" VerticalAlignment="Bottom" HorizontalAlignment="Left" 
                Background="{StaticResource BeigeLight}" BorderBrush="{StaticResource BeigeLight}" Cursor="Hand" Style="{StaticResource MaterialDesignFloatingActionLightButton}">
            <Image Width="30" Source="/Images/profile_icon.png"></Image>
        </Button>

        <Button Grid.Row="1" Width="60" Height="60" Margin="25" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                Background="{StaticResource DeepBrown}" BorderBrush="{StaticResource DeepBrown}" Cursor="Hand" Style="{StaticResource MaterialDesignFloatingActionDarkButton}">
            <Image Width="35" Source="/Images/handbag.png"></Image>
        </Button>
    </Grid>
</Window>