<Window x:Class="CigarHouseApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Background="#F5F5F5"
        FontFamily="Segoe UI Semibold" 
        Title="Cigar House" Height="700" Width="950" Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="DeepBrown" Color="#4E342E"/>
        <SolidColorBrush x:Key="BeigeLight" Color="#D7CCC8"/>
        <SolidColorBrush x:Key="GoldAccent" Color="#CE9E6E"/>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="BgBorder"
                                Background="{StaticResource DeepBrown}"
                                CornerRadius="5"
                                Margin="4,5"
                                MinWidth="110"
                                Height="55">
                            <ContentPresenter x:Name="ContentSite"
                                            ContentSource="Header"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#6D4C41"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource BeigeLight}"/>
                                <Setter Property="Foreground" Value="{StaticResource DeepBrown}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid Height="75">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="КАТАЛОГ" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{StaticResource DeepBrown}" FontSize="18" FontWeight="Black"/>

                <TabControl Grid.Column="1" 
                            Background="Transparent" 
                            BorderThickness="0"
                            SelectedIndex="-1"
                            x:Name="tabControlProducts"
                            SelectionChanged="TabControl_SelectionChanged">
                    <TabControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </TabControl.ItemsPanel>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/cigar_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="СИГАРЫ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/cigarillo_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="СИГАРИЛЛЫ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/lighter_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="АКСЕССУАРЫ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/sets_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="НАБОРЫ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/Images/ranking_icon.png" Width="18" Height="18" Margin="0,0,0,2"/>
                                <TextBlock Text="ЛУЧШЕЕ" FontSize="11"/>
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <materialDesign:Card Grid.Row="1" Margin="15" Padding="15" Background="White" UniformCornerRadius="10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" Grid.Column="0" Margin="5" Height="30" BorderBrush="{StaticResource BeigeLight}" BorderThickness="1"/>
                    <ListBox Grid.Row="0" Grid.Column="1" Margin="5" Height="30" BorderBrush="{StaticResource BeigeLight}" BorderThickness="1"/>
                    <TextBox Grid.Row="0" Grid.Column="2" Margin="5" Height="30" VerticalContentAlignment="Center" BorderBrush="{StaticResource DeepBrown}" BorderThickness="0,0,0,1"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="5,15,5,0">
                        <TextBlock Margin="0,0,0,5" Text="Цена" Foreground="Gray" FontSize="11"/>
                        <Slider Minimum="0" Maximum="100" IsSelectionRangeEnabled="True" Foreground="{StaticResource GoldAccent}" ValueChanged="Slider_ValueChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5,15,5,0">
                        <TextBlock Cursor="Hand" FontWeight="Bold" Foreground="{StaticResource DeepBrown}" Text="ДОП. ФИЛЬТРЫ"/>
                    </StackPanel>

                    <StackPanel x:Name="additionFilters" Visibility="Visible" Grid.Row="2" Grid.ColumnSpan="4" Margin="0,15,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Крепость" Foreground="Gray" FontSize="11" Margin="0,0,0,5"/>
                                <ListBox Height="25" BorderBrush="{StaticResource BeigeLight}" BorderThickness="1"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Длина" Foreground="Gray" FontSize="11"/>
                                    <TextBox Width="30" Margin="5,0" FontSize="10"/>
                                    <TextBlock Text="-" Foreground="Gray"/>
                                    <TextBox Width="30" Margin="5,0" FontSize="10"/>
                                </StackPanel>
                                <Slider Minimum="0" Maximum="100" Foreground="{StaticResource GoldAccent}" ValueChanged="Slider_ValueChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="5">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Толщина" Foreground="Gray" FontSize="11"/>
                                    <TextBox Width="30" Margin="5,0" FontSize="10"/>
                                    <TextBlock Text="-" Foreground="Gray"/>
                                    <TextBox Width="30" Margin="5,0" FontSize="10"/>
                                </StackPanel>
                                <Slider Minimum="0" Maximum="100" Foreground="{StaticResource GoldAccent}" ValueChanged="Slider_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </materialDesign:Card>

        <Frame Grid.Row="2" x:Name="cigarFrame" NavigationUIVisibility="Hidden"/>

        <Button Grid.Row="2" Width="50" Height="50" Margin="25" VerticalAlignment="Bottom" HorizontalAlignment="Left" 
                Background="{StaticResource BeigeLight}" BorderBrush="{StaticResource BeigeLight}" Cursor="Hand" Style="{StaticResource MaterialDesignFloatingActionLightButton}">
            <Image Width="30" Source="/Images/profile_icon.png"></Image>
        </Button>

        <Button Grid.Row="2" Width="60" Height="60" Margin="25" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                Background="{StaticResource DeepBrown}" BorderBrush="{StaticResource DeepBrown}" Cursor="Hand" Style="{StaticResource MaterialDesignFloatingActionDarkButton}">
            <Image Width="35" Source="/Images/handbag.png"></Image>
        </Button>
    </Grid>
</Window>