<Window x:Class="CigarHouseApp.Views.UserUpdateProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование профиля" 
        xmlns:helpers="clr-namespace:CigarHouseApp.Helpers"
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BeigeLight}">

    <Window.Resources>
        <helpers:ProductConverter x:Key="ProductConverter"/>
        <helpers:AvatarsConverter x:Key="AvatarsConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource MediumBrown}" Padding="25,20">
            
            <StackPanel>
                <TextBlock Text="Редактирование профиля" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextLight}"
                           FontFamily="B612 Mono"/>
                <TextBlock Text="Измените свои персональные данные" 
                           FontSize="12" 
                           Foreground="{StaticResource BeigeMedium}"
                           FontFamily="B612 Mono"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="svUser" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="30,25,30,15">
                <StackPanel Margin="0,0,0,25" HorizontalAlignment="Center">
                    <Grid Width="120" Height="120" Margin="0,0,0,10">

                        <Border x:Name="AvatarPlaceholder" 
                                CornerRadius="60"
                                Visibility="Visible">
                            <Border.Background>
                                <ImageBrush x:Name="imgBrushAvatar" ImageSource="{Binding Image, Converter={StaticResource AvatarsConverter}}"
                    Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                    </Grid>
                    <Button x:Name="UploadAvatarButton" 
                            Content="Загрузить аватарку"
                            Style="{StaticResource BasicButton}"
                            Width="180"
                            Height="36"
                            Click="UploadAvatarButton_Click"/>

                    <Button x:Name="RemoveAvatarButton" 
                            Content="Удалить аватарку"
                            Style="{StaticResource BasicButton}"
                            Width="180"
                            Height="36"
                            Margin="0,8,0,0"
                            Visibility="Collapsed"
                           />
                </StackPanel>
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Имя" 
                               FontFamily="B612 Mono" 
                               FontSize="12" 
                               Foreground="{StaticResource MediumBrown}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="tbFirstName" 
                             Text="{Binding FirstName}"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Фамилия" 
                               FontFamily="B612 Mono" 
                               FontSize="12" 
                               Foreground="{StaticResource MediumBrown}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="tbLastName" 
                             Text="{Binding LastName}"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Логин" 
                               FontFamily="B612 Mono" 
                               FontSize="12" 
                               Foreground="{StaticResource MediumBrown}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="tbLogin" 
                             Text="{Binding Login}"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Телефон" 
                               FontFamily="B612 Mono" 
                               FontSize="12" 
                               Foreground="{StaticResource MediumBrown}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="tbPhone" 
                             Text="{Binding Phone}"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Email" 
                               FontFamily="B612 Mono" 
                               FontSize="12" 
                               Foreground="{StaticResource MediumBrown}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="tbEmail" 
                             Text="{Binding Email}"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Дата рождения" 
                               FontFamily="B612 Mono" 
                               FontSize="12" 
                               Foreground="{StaticResource MediumBrown}"
                               Margin="0,0,0,5"/>
                    <DatePicker x:Name="dpBirthDate" SelectedDate="{Binding Birthday}" Style="{StaticResource MaterialDesignDatePicker}" ></DatePicker>
                </StackPanel>

                <Button x:Name="ChangePasswordButton" 
                        Content="Изменить пароль"
                        Style="{StaticResource BasicButton}"
                        Margin="0,10,0,20"
                        Click="ChangePasswordButton_Click"/>

                <StackPanel x:Name="PasswordPanel" 
                            Visibility="Collapsed"
                            Margin="0,0,0,20">

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Текущий пароль" 
                                   FontFamily="B612 Mono" 
                                   FontSize="12" 
                                   Foreground="{StaticResource MediumBrown}"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="pbCurrentPassword" 
                                     Password=""
                                     Style="{StaticResource ModernPasswordBox}"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Новый пароль" 
                                   FontFamily="B612 Mono" 
                                   FontSize="12" 
                                   Foreground="{StaticResource MediumBrown}"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="pbNewPassword" 
                                     Style="{StaticResource ModernPasswordBox}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Подтверждение пароля" 
                                   FontFamily="B612 Mono" 
                                   FontSize="12" 
                                   Foreground="{StaticResource MediumBrown}"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="pbConfirmPassword" 
                                     Style="{StaticResource ModernPasswordBox}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="{StaticResource BeigeMedium}"
                BorderThickness="0,1,0,0"
                Padding="25,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" 
                        Content="Отмена"
                        Style="{StaticResource BasicButton}"
                        Width="120"
                        Margin="0,0,15,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" 
                        Content="Сохранить"
                        Style="{StaticResource BasicButton2}"
                        Width="120"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>