<Page x:Class="CigarHouseApp.Pages.FavoritesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="950"
      Background="#FAF7F2"
      xmlns:helpers="clr-namespace:CigarHouseApp.Helpers"
      Title="Избранное" Loaded="Page_Loaded">

    <Page.Resources>
        <helpers:ProductConverter x:Key="ProductConverter"/>
        <helpers:ImageConverter x:Key="ImageConverter"/>
    </Page.Resources>

    <ScrollViewer  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Width="40" Height="40" Margin="0,0,15,0" Cursor="Hand" Style="{StaticResource HeartButton}">
                            <Image Source="/Images/back_arrow.png" Width="20" Height="20"/>
                        </Button>
                        <TextBlock Text="ИЗБРАННОЕ" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DeepBrown}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource HeartRed}" CornerRadius="15" Padding="10,5" Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="FavoritesCountText" Text="0 товаров" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Rectangle Height="2" Fill="{StaticResource BeigeMedium}" RadiusX="1" RadiusY="1"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Margin="0,15,0,25">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="AllProductsBtn" Click="FilterProductsBtn_Click" Style="{StaticResource ChipButtonStyle}" Content="Все товары"/>
                    <Button x:Name="CigarProductsBtn"  Click="FilterProductsBtn_Click" Style="{StaticResource ChipButtonStyle}" Content="Сигары"/>
                    <Button x:Name="AccessoryProductsBtn" Click="FilterProductsBtn_Click" Style="{StaticResource ChipButtonStyle}" Content="Аксессуары"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <ListView x:Name="favoriteListView">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource FavoriteCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="180"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Button Grid.Row="0" 
                            x:Name="HeartButton"
                            Click="HeartButton_Click"   
                            Style="{StaticResource HeartButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0"
                            />

                                        <Button Click="ToProductPage_Click"
                                                Background="Transparent" 
                                                BorderBrush="Transparent"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Width="Auto"
                                                Height="Auto"
                                                Padding="0" 
                                                Margin="0,10"
                                                Cursor="Hand">
                                            <Image Grid.Row="0" 
                               Source="{Binding Image, Converter={StaticResource ImageConverter}}" 
                               Stretch="Uniform"
                               Margin="15,15,15,5"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Width="140"
                               Height="140"/>
                                        </Button>

                                        <TextBlock Grid.Row="1" 
                               Text="{Binding Brand.Name}" 
                               FontSize="12"
                               Foreground="{StaticResource MediumBrown}"
                               FontWeight="SemiBold"
                               Margin="15,5,15,0"
                               TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Row="2" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DeepBrown}"
                               Margin="15,5,15,0"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="40">
                        <Hyperlink Click="ToProductPage_Click" 
                                   TextDecorations="None" 
                                   Foreground="{StaticResource DeepBrown}">
                            <Run Text="{Binding ProductName}"/>
                        </Hyperlink>
                                        </TextBlock>

                                        <TextBlock Grid.Row="3" 
                               Text="{Binding Price, StringFormat={}{0:C}}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrown}"
                               Margin="15,10,15,0"/>

                                        <Button Grid.Row="4" 
                            Style="{StaticResource CartButton}"
                            x:Name="tbAddToCartButton"
                                                Click="tbAddToCartButton_Click"
                            Height="40"
                            Margin="15,8,15,12"
                            HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>