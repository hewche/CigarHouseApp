<Page x:Class="CigarHouseApp.Pages.FavoritesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="950"
      Background="#FAF7F2"
      xmlns:helpers="clr-namespace:CigarHouseApp.Helpers"
      Title="Избранное" Loaded="Page_Loaded">

    <Page.Resources>
        <helpers:ProductConverter x:Key="ProductConverter"/>
        <helpers:ImageConverter x:Key="ImageConverter"/>
        <SolidColorBrush x:Key="DeepBrown" Color="#3E2A27"/>
        <SolidColorBrush x:Key="MediumBrown" Color="#6B4C3B"/>
        <SolidColorBrush x:Key="WarmBrown" Color="#8B5A4A"/>
        <SolidColorBrush x:Key="BeigeLight" Color="#F2E8DF"/>
        <SolidColorBrush x:Key="BeigeMedium" Color="#E8DDD2"/>
        <SolidColorBrush x:Key="AccentBrown" Color="#9B6B4A"/>
        <SolidColorBrush x:Key="HeartRed" Color="#E74C3C"/>

        <Style x:Key="FavoriteCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.15"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddToCartButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{StaticResource AccentBrown}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource WarmBrown}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Width="40" Height="40" Margin="0,0,15,0" Cursor="Hand" Style="{StaticResource HeartButton}">
                            <Image Source="/Images/back_arrow.png" Width="20" Height="20"/>
                        </Button>
                        <TextBlock Text="ИЗБРАННОЕ" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DeepBrown}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource HeartRed}" CornerRadius="15" Padding="10,5" Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="FavoritesCountText" Text="0 товаров" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Rectangle Height="2" Fill="{StaticResource BeigeMedium}" RadiusX="1" RadiusY="1"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Margin="0,15,0,25">
                <StackPanel Orientation="Horizontal">
                    <Border Background="White" CornerRadius="20" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="Все товары" FontSize="13" Foreground="{StaticResource DeepBrown}"/>
                    </Border>
                    <Border Background="White" CornerRadius="20" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="Сигары" FontSize="13" Foreground="{StaticResource DeepBrown}"/>
                    </Border>
                    <Border Background="White" CornerRadius="20" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Text="Аксессуары" FontSize="13" Foreground="{StaticResource DeepBrown}"/>
                    </Border>
                    <Border Background="White" CornerRadius="20" Padding="12,6">
                        <TextBlock Text="Наборы" FontSize="13" Foreground="{StaticResource DeepBrown}"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <ListView x:Name="favoriteListView">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource FavoriteCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="180"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Button Grid.Row="0" 
                            x:Name="HeartButton"
                            Click="HeartButton_Click"   
                            Style="{StaticResource HeartButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0"
                            />

                                        <Button Click="ToProductPage_Click"
                                                Background="Transparent" 
                                                BorderBrush="Transparent"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Width="Auto"
                                                Height="Auto"
                                                Padding="0" 
                                                Margin="0,10"
                                                Cursor="Hand">
                                            <Image Grid.Row="0" 
                               Source="{Binding Image, Converter={StaticResource ImageConverter}}" 
                               Stretch="Uniform"
                               Margin="15,15,15,5"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Width="140"
                               Height="140"/>
                                        </Button>

                                        <TextBlock Grid.Row="1" 
                               Text="{Binding Brand.Name}" 
                               FontSize="12"
                               Foreground="{StaticResource MediumBrown}"
                               FontWeight="SemiBold"
                               Margin="15,5,15,0"
                               TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Row="2" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DeepBrown}"
                               Margin="15,5,15,0"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="40">
                        <Hyperlink Click="ToProductPage_Click" 
                                   TextDecorations="None" 
                                   Foreground="{StaticResource DeepBrown}">
                            <Run Text="{Binding ProductName}"/>
                        </Hyperlink>
                                        </TextBlock>

                                        <TextBlock Grid.Row="3" 
                               Text="{Binding Price, StringFormat={}{0:C}}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrown}"
                               Margin="15,10,15,0"/>

                                        <Button Grid.Row="4" 
                            Style="{StaticResource AddToCartButton}"
                            Content="В КОРЗИНУ"
                            Margin="15,8,15,12"
                            HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>