<Page x:Class="CigarHouseApp.Pages.AddProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="950"
      Title="AddProductPage"
      Background="{StaticResource BeigeLight}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="ДОБАВЛЕНИЕ ТОВАРА"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource DeepBrown}"/>
                <TextBlock Text="Создайте новый товар, загрузите изображение и сохраните в базу."
                           Margin="0,8,0,0"
                           Foreground="{StaticResource MediumBrown}"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="14"
                    Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Название" FontWeight="SemiBold" Foreground="{StaticResource AccentBrown}"/>
                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="tbProductName" Style="{StaticResource ModernTextBox}" Margin="0,5,15,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Тип товара" FontWeight="SemiBold" Foreground="{StaticResource AccentBrown}"/>
                    <ComboBox Grid.Row="3" Grid.Column="0" x:Name="cbProductType" Style="{StaticResource ModernComboBox}" Margin="0,5,15,10" DisplayMemberPath="Name"/>

                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Text="Бренд" FontWeight="SemiBold" Foreground="{StaticResource AccentBrown}"/>
                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource DeepBrown}">
                            <Hyperlink x:Name="addBrandlink" Click="addBrandlink_Click" FontSize="8" Foreground="{StaticResource AccentBrown}">Добавить бренд</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                    <ComboBox Grid.Row="5" Grid.Column="0" x:Name="cbBrand" Style="{StaticResource ModernComboBox}" Margin="0,5,15,10" DisplayMemberPath="Name"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Страна" FontWeight="SemiBold" Foreground="{StaticResource AccentBrown}"/>
                    <ComboBox Grid.Row="7" Grid.Column="0" x:Name="cbCountry" Style="{StaticResource ModernComboBox}" Margin="0,5,15,0" DisplayMemberPath="CountryName"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Цена" FontWeight="SemiBold" Foreground="{StaticResource AccentBrown}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="tbCost" Style="{StaticResource ModernTextBox}" Margin="0,5,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Количество" FontWeight="SemiBold" Foreground="{StaticResource AccentBrown}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="tbQuantity" Style="{StaticResource ModernTextBox}" Margin="0,5,0,10"/>

                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Изображение" FontWeight="SemiBold" Foreground="{StaticResource AccentBrown}"/>
                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,5,0,10">
                        <Button Content="Выбрать изображение"
                                Click="btnLoadImage_Click"
                                Style="{StaticResource BasicButton}"
                                Width="180"/>
                        <TextBlock x:Name="tbSelectedImage"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource MediumBrown}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Row="6" Grid.RowSpan="3" Grid.Column="1" Margin="0,15,0,0"
                            BorderBrush="{StaticResource BeigeMedium}" BorderThickness="1" CornerRadius="10" Height="180">
                        <Image x:Name="imgPreview" Stretch="Uniform" Margin="8"/>
                    </Border>
                    <StackPanel Grid.Row="9" Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Очистить"
                            Click="btnClear_Click"
                            Style="{StaticResource BasicButton}"
                            Width="150"
                            Margin="0,0,10,0"/>
                                        <Button Content="Добавить товар"
                            Click="btnAddProduct_Click"
                            Style="{StaticResource BasicButton2}"
                            Width="180"/>
                    </StackPanel>
                </Grid>
                
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
