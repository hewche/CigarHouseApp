<Page x:Class="CigarHouseApp.Pages.ListProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CigarHouseApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListProductsPage">

    <Grid>
        <Grid>

            <ListView x:Name="listViewProducts" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VerticalContentAlignment="Stretch">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Button>
                                    <Image></Image>
                                </Button>
                                <StackPanel>
                                    <TextBlock x:Name="tbBrandName" Text="{Binding Name}"></TextBlock>
                                    <TextBlock x:Name="tbProductName" Text="{Binding ProductName}"/>
                                    <TextBlock x:Name="tbStrength" Text="{Binding Strength}"></TextBlock>
                                </StackPanel>
                                <Image/>
                                <StackPanel>
                                    <TextBlock x:Name="tbPrice" Text="{Binding CostProduct}"></TextBlock>
                                    <Border CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition></ColumnDefinition>
                                                <ColumnDefinition></ColumnDefinition>
                                                <ColumnDefinition></ColumnDefinition>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="minusButton"></Button>
                                            <TextBlock x:Name="tbCountProduct"  Text="0"/>
                                            <Button x:Name="plusButton"></Button>
                                        </Grid>
                                    </Border>
                                    <Button>
                                        <Image></Image>
                                    </Button>
                                </StackPanel>
                                <Button x:Name="tbBuyButton" Content="Купить в 1 клик"></Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
