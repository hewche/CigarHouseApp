<Page x:Class="CigarHouseApp.Pages.ListProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:CigarHouseApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="ListProductsPage" Loaded="Page_Loaded"
      FontFamily="Segoe UI Semibold">

    <Page.Resources>
        <SolidColorBrush x:Key="DeepBrown" Color="#4E342E"/>
        <SolidColorBrush x:Key="BeigeLight" Color="#D7CCC8"/>
        <SolidColorBrush x:Key="GoldAccent" Color="#CE9E6E"/>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <materialDesign:Card Grid.Row="0" Visibility="Visible" x:Name="cardFilters" Margin="15" Padding="15" Background="White" UniformCornerRadius="10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="4" x:Name="spFiltersMain1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Margin="0,0,0,5" Text="Страна" Foreground="Black" FontSize="11"/>
                                <ComboBox SelectionChanged="lbCountry_SelectionChanged"
          materialDesign:HintAssist.Hint="Выберите страну"
          BorderBrush="{StaticResource BeigeLight}" x:Name="lbCountry" Foreground="Black" Margin="5" Height="30"  BorderThickness="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Margin="0,0,0,5" Text="Марка" Foreground="Black" FontSize="11"/>
                                <ComboBox SelectionChanged="lbBrand_SelectionChanged" materialDesign:HintAssist.Hint="Выберите страну"
BorderBrush="{StaticResource BeigeLight}" x:Name="lbBrand" Foreground="Black" Margin="5" Height="30"  BorderThickness="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="5" VerticalAlignment="Bottom">
                                <TextBox Height="30" BorderBrush="{StaticResource DeepBrown}" BorderThickness="0,0,0,1"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="4" x:Name="spFiltersMain2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="5,15,5,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                    <TextBlock Margin="0 0 10 5" VerticalAlignment="Center" Text="Цена" Foreground="Gray" FontSize="11"/>
                                    <TextBox  BorderBrush="Gray" Width="40" Height="20"></TextBox>
                                    <TextBlock Margin="5 0 5 0" VerticalAlignment="Center" Text="-"></TextBlock>
                                    <TextBox BorderBrush="Gray" Width="40" Height="20"></TextBox>
                                </StackPanel>
                                <Slider Minimum="0" Maximum="100" IsSelectionRangeEnabled="True" Foreground="{StaticResource GoldAccent}" ValueChanged="Slider_ValueChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5,15,5,0">
                                <TextBlock x:Name="tbFilters" Cursor="Hand">
                                    <Hyperlink Click="tbFilters_Click" Foreground="{StaticResource DeepBrown}"  FontWeight="Bold" TextDecorations="None">
                                        <Run Text="Доп. фильтры"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>


                    <StackPanel x:Name="additionFilters" Visibility="Hidden" Grid.Row="2" Grid.ColumnSpan="4" Margin="0,15,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Крепость" Foreground="Gray" FontSize="11" Margin="0,0,0,5"/>
                                <ListBox Height="25" BorderBrush="{StaticResource BeigeLight}" BorderThickness="1"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Длина" Foreground="Gray" FontSize="11"/>
                                    <TextBox Width="30" Margin="5,0" FontSize="10"/>
                                    <TextBlock Text="-" Foreground="Gray"/>
                                    <TextBox Width="30" Margin="5,0" FontSize="10"/>
                                </StackPanel>
                                <Slider Minimum="0" Maximum="100" Foreground="{StaticResource GoldAccent}" ValueChanged="Slider_ValueChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="5">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="Толщина" Foreground="Gray" FontSize="11"/>
                                    <TextBox Width="30" Margin="5,0" FontSize="10"/>
                                    <TextBlock Text="-" Foreground="Gray"/>
                                    <TextBox Width="30" Margin="5,0" FontSize="10"/>
                                </StackPanel>
                                <Slider Minimum="0" Maximum="100" Foreground="{StaticResource GoldAccent}" ValueChanged="Slider_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </materialDesign:Card>
        <ListView x:Name="listViewProducts" 
                  BorderThickness="0" 
                  Background="Transparent"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  MaxWidth="1150" 
                  Grid.Row="1"
                  >

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Left" ItemWidth="370"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card Width="345" Height="550" Margin="10" UniformCornerRadius="15" Background="White">
                        <materialDesign:Card.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.12"/>
                        </materialDesign:Card.Effect>

                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="220"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <TextBlock Text="{Binding Brand.Name}" 
                                           Foreground="{StaticResource GoldAccent}" 
                                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right" Width="36" Height="36" Padding="0"
                                        Background="Transparent" BorderThickness="0" 
                                        Style="{StaticResource MaterialDesignToolButton}">
                                    <Image Source="/Images/heart_icon.png" Width="22" Opacity="0.7"/>
                                </Button>
                            </Grid>

                            <StackPanel Grid.Row="1" Margin="0,5,0,0" Height="65">
                                <TextBlock FontSize="19" FontWeight="Black" TextWrapping="Wrap" MaxHeight="50">
                                    <Hyperlink Click="tbProductName_Click" TextDecorations="None" Foreground="{StaticResource DeepBrown}">
                                        <Run Text="{Binding ProductName}"/>
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock Text="{Binding Cigar.Strength}" Foreground="Gray" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Button Grid.Row="2" x:Name="btnImage" Click="btnImage_Click" 
                                Background="Transparent" 
                                BorderBrush="Transparent"
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" 
                                VerticalContentAlignment="Stretch"
                                Height="130"
                                Padding="0" 
                                Margin="0,10">
                                <Image Source="/Images/Image_not_available.png" 
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>

                            <Grid Grid.Row="3" Margin="0,15">
                                <TextBlock Text="{Binding CostProduct}" 
                                           Foreground="{StaticResource DeepBrown}" 
                                           FontSize="24" FontWeight="Black" VerticalAlignment="Center"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border BorderBrush="{StaticResource BeigeLight}" BorderThickness="1.5" CornerRadius="20" Height="40">
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="minusButton" Content="-" Width="35" Height="35" Padding="0"
                                                    Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource DeepBrown}" FontSize="20"/>
                                            <TextBlock x:Name="tbCountProduct" Text="0" 
                                                       VerticalAlignment="Center" Margin="15,0" 
                                                       Foreground="Black" FontSize="16" FontWeight="Bold"/>
                                            <Button x:Name="plusButton" Content="+" Width="35" Height="35" Padding="0"
                                                    Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource DeepBrown}" FontSize="20"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,5,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" x:Name="tbBuyButton" 
                                        Content="КУПИТЬ В 1 КЛИК" 
                                        FontSize="13" Height="48" FontWeight="Bold"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        BorderBrush="{StaticResource DeepBrown}"
                                        Foreground="{StaticResource DeepBrown}"/>

                                <Button Grid.Column="1" Margin="15,0,0,0" Width="50" Height="50" Padding="12"
                                        Background="{StaticResource DeepBrown}" BorderBrush="{StaticResource DeepBrown}"
                                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}">
                                    <Image Source="/Images/handbag.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>