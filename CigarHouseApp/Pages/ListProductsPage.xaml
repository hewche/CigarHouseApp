<Page x:Class="CigarHouseApp.Pages.ListProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CigarHouseApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListProductsPage" Loaded="Page_Loaded"
      FontFamily="B612 Mono">
    <Grid>
        <Grid>

            <ListView x:Name="listViewProducts" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VerticalContentAlignment="Stretch">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel MaxWidth="1200" HorizontalAlignment="Center" Orientation="Horizontal" 
                       ItemWidth="310"
                            ItemHeight="390"
                            Margin="10"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="5"  
                    Padding="10"
                    Width="290"> 
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.15*"></RowDefinition>
                                    <RowDefinition Height="0.4*"></RowDefinition>
                                    <RowDefinition Height="0.5*"></RowDefinition>
                                    <RowDefinition Height="0.4*"></RowDefinition>
                                    <RowDefinition Height="0.2*"></RowDefinition>
                                </Grid.RowDefinitions>
                                <Button Background="Transparent" BorderThickness="0" Padding="2" Width="23" Height="23" Grid.Row="0" HorizontalAlignment="Right" Margin="5">
                                    <Image Source="/Images/heart_icon.png"></Image>
                                </Button >
                                <StackPanel Grid.Row="1" Margin="5" HorizontalAlignment="Center">
                                    <TextBlock Margin="5"  TextAlignment="Center" Foreground="Black" x:Name="tbBrandName" Text="{Binding Brand.Name}"></TextBlock>
                                    <TextBlock Margin="5" TextAlignment="Center" Foreground="Black" x:Name="tbProductName" Text="{Binding ProductName}"/>
                                    <TextBlock Margin="5" TextAlignment="Center" Foreground="Black" x:Name="tbStrength" Text="{Binding Cigar.Strength}"></TextBlock>
                                </StackPanel>
                                <Image Margin="10" Grid.Row="2" Source="/Images/Image_not_available.png" Width="200" Height="120"/>
                                <StackPanel Grid.Row="3" Margin="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock TextAlignment="Center" VerticalAlignment="Center" x:Name="tbPrice" Foreground="Black" Text="{Binding Path=CostProduct}"></TextBlock>
                                    <Border Margin="70 0 0 0" CornerRadius="10" HorizontalAlignment="Right">
                                        <Grid Margin="10" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition></ColumnDefinition>
                                                <ColumnDefinition></ColumnDefinition>
                                                <ColumnDefinition></ColumnDefinition>
                                            </Grid.ColumnDefinitions>
                                            <Button Padding="2" Width="30" Background="Transparent" Grid.Column="0" x:Name="minusButton">
                                                <TextBlock Text="-" Foreground="#47352B"/>
                                            </Button>
                                            <TextBlock VerticalAlignment="Center" Grid.Column="1" Margin="5" x:Name="tbCountProduct" Foreground="Black" Text="0"/>
                                            <Button Padding="2" Width="30" Background="Transparent" Grid.Column="2" x:Name="plusButton">
                                                <TextBlock Text="+" Foreground="#47352B"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <Button Padding="2" HorizontalAlignment="Right"  Width="35" Height="35" Background="Transparent">
                                        <Image  Stretch="Uniform" VerticalAlignment="Center" Source="/Images/handbag.png"></Image>
                                    </Button>
                                </StackPanel>
                                <Button Margin="5" Grid.Row="4" x:Name="tbBuyButton" Content="Купить в 1 клик"></Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
