<Page x:Class="CigarHouseApp.Pages.ListProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CigarHouseApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListProductsPage" Loaded="Page_Loaded"
      FontFamily="B612 Mono">
    <Grid>
        <Grid>

            <ListView x:Name="listViewProducts" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VerticalContentAlignment="Stretch">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel MaxWidth="1200" HorizontalAlignment="Center" Orientation="Horizontal" 
                       ItemWidth="310"
                            ItemHeight="360"
                            Margin="10"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="5"  
                    Padding="10"
                    Width="290"> 
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                    <RowDefinition></RowDefinition>
                                </Grid.RowDefinitions>
                                <Button Width="30" Height="30" Background="Transparent" Grid.Row="0" HorizontalAlignment="Right" >
                                    <Image Source="/Images/heart_icon.png"></Image>
                                </Button >
                                <StackPanel Grid.Row="1" >
                                    <TextBlock Foreground="Black" x:Name="tbBrandName" Text="{Binding Brand.Name}"></TextBlock>
                                    <TextBlock Foreground="Black" x:Name="tbProductName" Text="{Binding ProductName}"/>
                                    <TextBlock Foreground="Black" x:Name="tbStrength" Text="{Binding Cigar.Strength}"></TextBlock>
                                </StackPanel>
                                <Image/>
                                <StackPanel Grid.Row="2">
                                    <TextBlock x:Name="tbPrice" Text="{Binding Path=CostProduct}"></TextBlock>
                                    <Border CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition></ColumnDefinition>
                                                <ColumnDefinition></ColumnDefinition>
                                                <ColumnDefinition></ColumnDefinition>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" x:Name="minusButton"></Button>
                                            <TextBlock Grid.Column="1" x:Name="tbCountProduct"  Text="0"/>
                                            <Button Grid.Column="2" x:Name="plusButton"></Button>
                                        </Grid>
                                    </Border>
                                    <Button>
                                        <Image></Image>
                                    </Button>
                                </StackPanel>
                                <Button Grid.Row="3" x:Name="tbBuyButton" Content="Купить в 1 клик"></Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
