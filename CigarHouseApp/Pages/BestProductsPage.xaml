<Page x:Class="CigarHouseApp.Pages.BestProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:CigarHouseApp.Pages" 
      xmlns:helpers="clr-namespace:CigarHouseApp.Helpers"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="BestProductsPage"
      FontFamily="Segoe UI"
      Background="#FAF7F2">

    <Page.Resources>
        <helpers:ProductConverter x:Key="ProductConverter"/>
        <helpers:ImageConverter x:Key="ImageConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource BeigeLight}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <materialDesign:Card Grid.Row="0" 
                            Margin="15,15,15,10" 
                            Padding="20,15" 
                            Background="White" 
                            UniformCornerRadius="12">
            <materialDesign:Card.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
            </materialDesign:Card.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource BeigeLight}" 
                        CornerRadius="10" 
                        Padding="15,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏆" FontSize="22" Margin="0,0,8,0"/>
                        <TextBlock Text="Лучшие товары" 
                                   Foreground="{StaticResource AccentBrown}" 
                                   FontSize="18" 
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="1" 
                           Text="Топ-10 товаров по рейтингу покупателей"
                           Foreground="{StaticResource MediumBrown}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Opacity="0.7"/>
            </Grid>
        </materialDesign:Card>

        <!-- Загрузка -->
        <Grid Grid.Row="1" x:Name="loadingGrid" Background="{StaticResource BeigeLight}" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" 
                        Width="250" 
                        Height="3"
                        Foreground="{StaticResource AccentBrown}"
                        Background="{StaticResource BeigeMedium}"/>
                <TextBlock Text="Загрузка лучших товаров..." 
                       Margin="0,20,0,0" 
                       Foreground="{StaticResource AccentBrown}"
                       FontSize="14"
                       FontWeight="SemiBold"/>
                <TextBlock x:Name="loadingStatusText" 
                       Text="Подключение к базе данных..." 
                       Margin="0,10,0,0" 
                       Foreground="#999999"
                       FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Список товаров -->
        <ListView x:Name="listViewProducts" 
          BorderThickness="0" 
          Background="Transparent"
          VirtualizingPanel.IsVirtualizing="True"
          VirtualizingPanel.VirtualizationMode="Recycling"
          VirtualizingPanel.ScrollUnit="Pixel"
          ScrollViewer.IsDeferredScrollingEnabled="True"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          VerticalAlignment="Top"
          HorizontalAlignment="Center"
          MaxWidth="1400" 
          Grid.Row="1"
          Margin="0,15,0,0"
          >

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Left" ItemWidth="420"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card Width="390" Height="650" Margin="15" UniformCornerRadius="15" Background="White">
                        <materialDesign:Card.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                        </materialDesign:Card.Effect>

                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="320"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Border Background="{StaticResource BeigeLight}" 
                                CornerRadius="6" 
                                Padding="12,6"
                                HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Brand.Name}" 
                                       Foreground="{StaticResource AccentBrown}" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"/>
                                </Border>
                                <Button Grid.Row="0" 
                            x:Name="HeartButton"
                            Click="HeartButton_Click"   
                            Style="{StaticResource HeartButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0"
                            Tag="{Binding}"
                            />
                            </Grid>

                            <StackPanel Grid.Row="1" Margin="0,15,0,0">
                                <TextBlock FontSize="20" FontWeight="Bold" TextWrapping="Wrap" MaxHeight="60">
                            <Hyperlink Click="tbProductName_Click" 
                                       TextDecorations="None" 
                                       Foreground="{StaticResource DeepBrown}">
                                <Run Text="{Binding ProductName}"/>
                            </Hyperlink>
                                </TextBlock>
                                <TextBlock Text="{Binding Converter={StaticResource ProductConverter}}" 
                                   Foreground="#888888" 
                                   FontSize="12" 
                                   Margin="0,8,0,0"/>
                            </StackPanel>

                            <Button Grid.Row="2" x:Name="btnImage" Click="btnImage_Click" 
                            Background="Transparent" 
                            BorderBrush="Transparent"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="260"
                            Height="260"
                            Padding="0" 
                            Margin="0,10"
                            Cursor="Hand">
                                <Image Source="{Binding Image, Converter={StaticResource ImageConverter}}" 
                               Stretch="Uniform"
                               Width="260"
                               Height="260"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Button>

                            <Grid Grid.Row="3" Margin="0,15">
                                <TextBlock Foreground="{StaticResource AccentBrown}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} ₽">
                                            <Binding Path="CostProduct"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <Border BorderBrush="{StaticResource BeigeMedium}" 
                                BorderThickness="1.5" 
                                CornerRadius="25" 
                                Height="46"
                                HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="minusButton"
                                        Click="minusButton_Click"
                                        Content="−" 
                                        Width="42" 
                                        Height="42" 
                                        Padding="0"
                                        Style="{StaticResource ModernCounterButton}"/>
                                        <TextBlock x:Name="tbCountProduct" 
                                           Text="{Binding PurchaseAmount}" 
                                           VerticalAlignment="Center" 
                                           MinWidth="40"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource TextDark}" 
                                           FontSize="18" 
                                           FontWeight="SemiBold"/>
                                        <Button x:Name="plusButton" 
                                        Click="plusButton_Click"
                                        Content="+" 
                                        Width="42" 
                                        Height="42" 
                                        Padding="0"
                                        Style="{StaticResource ModernCounterButton}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Button Grid.Row="4" Margin="0,20,0,0" 
                        Width="200"
                        x:Name="tbAddToCartButton"
                        Click="tbAddToCartButton_Click"
                        Style="{StaticResource CartButton}"
                        Tag="{Binding}"/>
                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>