<Page x:Class="CigarHouseApp.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CigarHouseApp.Pages"
      FontFamily="Exo 2 Extra Bold"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductPage">

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.2*" ></RowDefinition>
                <RowDefinition Height="0.6*"></RowDefinition>
                <RowDefinition Height="0.3*"></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="0.1*"></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Center" x:Name="tbBrandName" Text="Название бренда"></TextBlock>
            <StackPanel Grid.Row="1">
                <TextBlock HorizontalAlignment="Center" x:Name="tbProductName" Text="Название продукта"></TextBlock>
                <Image Source="/Images/Image_not_available.png" Width="300" Height="120" x:Name="imgProduct"></Image>
                <Button Width="200" Height="35" Style="{StaticResource PrimaryButtonKey}" x:Name="likeButton" Click="likeButton_Click" Content="Добавить в избранное"></Button>
            </StackPanel>
            <ListView Grid.Row="2" x:Name="ProductInfoListView" 
              MaxHeight="150">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Margin="5"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel Grid.Row="3">
                <Button Width="200" Height="35" Style="{StaticResource PrimaryButtonKey}" Content="Купить"></Button>
            </StackPanel>
            <StackPanel Grid.Row="4">

            </StackPanel>
        </Grid>
    </Grid>
</Page>
