<Page x:Class="CigarHouseApp.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:CigarHouseApp.Pages"
      FontFamily="Segoe UI Semibold"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="ProductPage">

    <Page.Resources>
        <SolidColorBrush x:Key="DeepBrown" Color="#4E342E"/>
        <SolidColorBrush x:Key="BeigeLight" Color="#D7CCC8"/>
        <SolidColorBrush x:Key="GoldAccent" Color="#CE9E6E"/>
    </Page.Resources>

    
    
    <Grid Background="#F5F5F5">

        
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <materialDesign:Card Margin="25" UniformCornerRadius="15" Background="White">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="tbBrandName" 
                               Text="{Binding Brand.Name}" 
                               HorizontalAlignment="Center" 
                               Foreground="{StaticResource GoldAccent}" 
                               FontSize="16" FontWeight="Bold" Margin="0,10"/>

                    <StackPanel Grid.Row="1" x:Name="spProductInfo" Margin="0,0,0,15">
                        <TextBlock HorizontalAlignment="Center" x:Name="tbProductName" 
                                   Text="{Binding ProductName}" 
                                   Foreground="{StaticResource DeepBrown}" 
                                   FontSize="26" FontWeight="Black" 
                                   TextAlignment="Center" Margin="0,0,0,15"/>

                        <Image Source="/Images/Image_not_available.png" 
                               Width="380" Height="160" 
                               Stretch="Uniform"
                               x:Name="imgProduct" Margin="0,0,0,15"/>

                        <Button Width="220" Height="40" 
                                x:Name="likeButton" Click="likeButton_Click" 
                                Content="В ИЗБРАННОЕ" 
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="{StaticResource BeigeLight}"
                                Foreground="{StaticResource DeepBrown}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" x:Name="svStatsCigar" MaxHeight="250" VerticalScrollBarVisibility="Auto" Margin="0,10">
                        <StackPanel HorizontalAlignment="Center" MinWidth="300">
                            <Border BorderBrush="{StaticResource BeigeLight}" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <TextBlock Text="Крепость:" Foreground="Gray" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding Cigar.Strength}" Foreground="{StaticResource DeepBrown}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <Border BorderBrush="{StaticResource BeigeLight}" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <TextBlock Text="Формат:" Foreground="Gray" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding Cigar.Vitola}" Foreground="{StaticResource DeepBrown}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <Border BorderBrush="{StaticResource BeigeLight}" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <TextBlock Text="Ring Gauge:" Foreground="Gray" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding Cigar.RingGauge}" Foreground="{StaticResource DeepBrown}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <Border BorderBrush="{StaticResource BeigeLight}" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <TextBlock Text="Вкус:" Foreground="Gray" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding Cigar.FlavorProfile}" Foreground="{StaticResource DeepBrown}" FontWeight="Bold" HorizontalAlignment="Right" MaxWidth="180" TextAlignment="Right" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Margin="0,20,0,10">
                        <Button Width="260" Height="50" 
                                Background="{StaticResource DeepBrown}" 
                                BorderBrush="{StaticResource DeepBrown}"
                                Content="КУПИТЬ" 
                                FontSize="15" FontWeight="Bold"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </ScrollViewer>
    </Grid>
</Page>