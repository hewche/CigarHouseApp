<Page x:Class="CigarHouseApp.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:CigarHouseApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="ProductPage"
      Background="#FAF7F2"
      FontFamily="Segoe UI">

    <Page.Resources>
        

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                
                <StackPanel Grid.Row="0">
                    <materialDesign:Card Margin="25" UniformCornerRadius="15" Background="White">
                        <materialDesign:Card.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
                        </materialDesign:Card.Effect>

                        
                        <Grid Margin="25">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Button x:Name="btnBack" 
                            Style="{StaticResource BackButtonStyle}"
                            Width="44" 
                            Height="44"
                            Margin="20,20,0,0"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Click="btnBack_Click"
                            Cursor="Hand">
                                <Viewbox Width="20" Height="20">
                                    <Path Fill="{StaticResource DeepBrown}" Data="M20,11H7.83L13.42,5.41L12,4L4,12L12,20L13.41,18.59L7.83,13H20V11Z"/>
                                </Viewbox>
                            </Button>
                            <TextBlock Grid.Row="0" x:Name="tbBrandName" 
                                   Text="{Binding Brand.Name}" 
                                   HorizontalAlignment="Center" 
                                   Foreground="{StaticResource AccentBrown}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Margin="0,5"/>

                            <StackPanel Grid.Row="1" x:Name="spProductInfo" Margin="0,0,0,15">
                                <TextBlock HorizontalAlignment="Center" x:Name="tbProductName" 
                                       Text="{Binding ProductName}" 
                                       Foreground="{StaticResource DeepBrown}" 
                                       FontSize="28" 
                                       FontWeight="Bold" 
                                       TextAlignment="Center" 
                                       Margin="0,0,0,15"/>

                                <Image Source="/Images/Image_not_available.png" 
                                   Width="380" Height="180" 
                                   Stretch="Uniform"
                                   x:Name="imgProduct" 
                                   Margin="0,0,0,20"/>

                                <Button Width="180" Height="38" 
                                    x:Name="likeButton" Click="likeButton_Click" 
                                    Content="В ИЗБРАННОЕ" 
                                    Style="{StaticResource BasicButton}"
                                    Cursor="Hand">
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Row="2" x:Name="svStatsCigar" MaxHeight="280" Margin="0,15">
                                <StackPanel HorizontalAlignment="Center" MinWidth="320">
                                    <Border BorderBrush="{StaticResource BeigeMedium}" BorderThickness="0,0,0,1" Padding="12,10">
                                        <Grid>
                                            <TextBlock Text="Крепость:" Foreground="#888888" FontSize="13"/>
                                            <TextBlock Text="{Binding Cigar.Strength}" Foreground="{StaticResource DeepBrown}" FontWeight="SemiBold" HorizontalAlignment="Right" FontSize="13"/>
                                        </Grid>
                                    </Border>

                                    <Border BorderBrush="{StaticResource BeigeMedium}" BorderThickness="0,0,0,1" Padding="12,10">
                                        <Grid>
                                            <TextBlock Text="Формат:" Foreground="#888888" FontSize="13"/>
                                            <TextBlock Text="{Binding Cigar.Vitola}" Foreground="{StaticResource DeepBrown}" FontWeight="SemiBold" HorizontalAlignment="Right" FontSize="13"/>
                                        </Grid>
                                    </Border>

                                    <Border BorderBrush="{StaticResource BeigeMedium}" BorderThickness="0,0,0,1" Padding="12,10">
                                        <Grid>
                                            <TextBlock Text="Ring Gauge:" Foreground="#888888" FontSize="13"/>
                                            <TextBlock Text="{Binding Cigar.RingGauge}" Foreground="{StaticResource DeepBrown}" FontWeight="SemiBold" HorizontalAlignment="Right" FontSize="13"/>
                                        </Grid>
                                    </Border>

                                    <Border BorderBrush="{StaticResource BeigeMedium}" BorderThickness="0,0,0,1" Padding="12,10">
                                        <Grid>
                                            <TextBlock Text="Вкус:" Foreground="#888888" FontSize="13"/>
                                            <TextBlock Text="{Binding Cigar.FlavorProfile}" Foreground="{StaticResource DeepBrown}" FontWeight="SemiBold" HorizontalAlignment="Right" MaxWidth="200" TextAlignment="Right" TextWrapping="Wrap" FontSize="13"/>
                                        </Grid>
                                    </Border>

                                    <Border BorderBrush="{StaticResource BeigeMedium}" BorderThickness="0,0,0,1" Padding="12,10">
                                        <Grid>
                                            <TextBlock Text="Страна:" Foreground="#888888" FontSize="13"/>
                                            <TextBlock Text="{Binding CountryNavigation.CountryName}" Foreground="{StaticResource DeepBrown}" FontWeight="SemiBold" HorizontalAlignment="Right" MaxWidth="200" TextAlignment="Right" TextWrapping="Wrap" FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Margin="0,20,0,10">
                                <Button Width="280" Height="52" 
                                    x:Name="addToCart"
                                    Click="addToCart_Click"
                                    Style="{StaticResource CartButton}"
                                    Tag="{Binding}">
                                </Button>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </StackPanel>

                <TextBlock Text="ОТЗЫВЫ" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource DeepBrown}"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,10"/>

                <StackPanel Orientation="Vertical" Width="550">
                    <TextBlock Text="Заголовок" HorizontalAlignment="Left" Style="{StaticResource MaterialDesignBody1TextBlock}"></TextBlock>
                    <TextBox
                        Width="500"
                        Height="Auto"
                        x:Name="tbHeader"
                        Style="{StaticResource ModernTextBox}"
                        materialDesign:HintAssist.Hint="Введите заголовок..."
                        TextWrapping="Wrap" Margin="0 10" 
                        HorizontalAlignment="Left"/>
                    <TextBlock Text="Отзыв" HorizontalAlignment="Left" Style="{StaticResource MaterialDesignBody1TextBlock}"></TextBlock>
                    <TextBox
                        Width="500"
                        Height="Auto"
                        x:Name="tbWriteReview"
                        Style="{StaticResource ModernTextBox}"
                        materialDesign:HintAssist.Hint="Оставить текст отзыва..."
                        TextWrapping="Wrap" Margin="0 10" 
                        HorizontalAlignment="Left"/>
                    <Button Content="Отправить"
                            Width="95"
                            HorizontalAlignment="Right"
                            Height="30"
                            Margin="15"
                            FontSize="12"
                            Click="btnAddReview_Click"/>
                </StackPanel>
                <ListView x:Name="listReview" 
                          BorderThickness="0" 
                          Background="Transparent"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,25"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled">

                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Height="Auto" Width="750" Margin="12" UniformCornerRadius="12" Background="White">
                                <materialDesign:Card.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08"/>
                                </materialDesign:Card.Effect>

                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Background="{StaticResource AccentBrown}" 
                                                CornerRadius="20" 
                                                Width="36" 
                                                Height="36"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="👤" 
                                                       FontSize="18" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock x:Name="tbLogin"  
                                                   VerticalAlignment="Center" 
                                                   Margin="12,0" 
                                                   Foreground="{StaticResource DeepBrown}" 
                                                   FontSize="16" 
                                                   FontWeight="SemiBold" 
                                                   Text="{Binding User.Login}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" x:Name="tbTitle" 
                                               VerticalAlignment="Center" 
                                               Margin="0,0,0,8" 
                                               Foreground="{StaticResource AccentBrown}" 
                                               FontSize="15" 
                                               FontWeight="SemiBold" 
                                               Text="{Binding Title}"/>

                                    <Border Grid.Row="2" 
                                            Background="{StaticResource BeigeLight}" 
                                            CornerRadius="10" 
                                            Margin="0,5,0,0" 
                                            Padding="15">
                                        <TextBlock x:Name="tbReviewText" 
                                                   VerticalAlignment="Center" 
                                                   Foreground="{StaticResource TextDark}" 
                                                   FontSize="14" 
                                                   Text="{Binding ReviewText}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>