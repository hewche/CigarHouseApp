<Page x:Class="CigarHouseApp.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:helpers="clr-namespace:CigarHouseApp.Helpers"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="950"
      Background="#FAF7F2"
      Title="Корзина" Loaded="Page_Loaded">

    <Page.Resources>
        <helpers:ProductConverter x:Key="ProductConverter"/>
        <helpers:ImageConverter x:Key="ImageConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Width="40" 
                                Height="40" 
                                Margin="0,0,15,0"
                                Cursor="Hand"
                                Style="{StaticResource RemoveButton}">
                            <Image Source="/Images/cigar_icon.png" Width="20" Height="20"/>
                        </Button>
                        <TextBlock Text="КОРЗИНА" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource DeepBrown}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{StaticResource AccentBrown}"
                                CornerRadius="15"
                                Padding="10,5"
                                Margin="15,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="tbItemsCount" 
                                       Text="0 товаров" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Rectangle Height="2" 
                               Fill="{StaticResource BeigeMedium}" 
                               RadiusX="1" 
                               RadiusY="1"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>


                <Border Grid.Column="0" Margin="0,0,25,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="550">
                        <ItemsControl x:Name="itemsControlCart" ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CartItemCard}">
                                        <Grid Margin="15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" 
                                                    Background="{StaticResource BeigeLight}"
                                                    CornerRadius="8"
                                                    Width="80"
                                                    Height="80">
                                                <Image Source="{Binding Image, Converter={StaticResource ImageConverter}}" 
                                                       Width="60" 
                                                       Height="60"
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" Margin="15,0">
                                                <TextBlock Text="{Binding ProductName}" 
                                                           FontSize="16" 
                                                           FontWeight="SemiBold" 
                                                           Foreground="{StaticResource DeepBrown}"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding Brand}" 
                                                           FontSize="12" 
                                                           Foreground="{StaticResource MediumBrown}"
                                                           Opacity="0.7"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <TextBlock Text="Цена: " 
                                                               FontSize="13" 
                                                               Foreground="{StaticResource TextDark}"
                                                               Opacity="0.6"/>
                                                    <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" 
                                                               FontSize="14" 
                                                               FontWeight="SemiBold" 
                                                               Foreground="{StaticResource AccentBrown}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" 
                                                        VerticalAlignment="Center" 
                                                        HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <Button Style="{StaticResource QuantityButton}" 
                                                            Tag="{Binding}">
                                                        <TextBlock Text="-" FontWeight="Bold"/>
                                                    </Button>
                                                    <TextBlock x:Name="tbQuantity" 
                                                               Text="{Binding Quantity}" 
                                                               Width="45" 
                                                               TextAlignment="Center"
                                                               FontSize="14" 
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource QuantityButton}" 
                                                            Tag="{Binding}">
                                                        <TextBlock Text="+" FontWeight="Bold"/>
                                                    </Button>
                                                </StackPanel>
                                                <Button Style="{StaticResource RemoveButton}"
                                                        Tag="{Binding}"
                                                        HorizontalAlignment="Right">
                                                    <Image Source="/Images/trash_icon.png" Width="16" Height="16"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ItemsControl">
                                                        <Border Style="{StaticResource CartItemCard}" Padding="40">
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Image Source="/Images/empty_cart.png" 
                                                                       Width="120" 
                                                                       Height="120" 
                                                                       Opacity="0.5"
                                                                       Margin="0,0,0,20"/>
                                                                <TextBlock Text="Ваша корзина пуста" 
                                                                           FontSize="18" 
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource DeepBrown}"
                                                                           Margin="0,0,0,10"/>
                                                                <TextBlock Text="Добавьте товары из каталога" 
                                                                           Style="{StaticResource EmptyCartText}"/>
                                                                
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1" 
                        Background="White" 
                        CornerRadius="12"
                        Padding="20"
                        Height="Auto">
                    <StackPanel>
                        <TextBlock Text="ОФОРМЛЕНИЕ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource DeepBrown}"
                                   Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Товары:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextDark}"
                                       Opacity="0.7"/>
                            <TextBlock x:Name="tbSubtotal" 
                                       Grid.Row="0" Grid.Column="1" 
                                       Text="0 ₽" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource DeepBrown}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Доставка:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextDark}"
                                       Opacity="0.7"
                                       Margin="0,10,0,0"/>
                            <TextBlock x:Name="tbDelivery" 
                                       Grid.Row="1" Grid.Column="1" 
                                       Text="0 ₽" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource DeepBrown}"
                                       Margin="0,10,0,0"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BeigeMedium}" Margin="0,5,0,15"/>

                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="ИТОГО:" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource DeepBrown}"/>
                            <TextBlock x:Name="tbTotal" 
                                       Grid.Column="1" 
                                       Text="0 ₽" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource AccentBrown}"/>
                        </Grid>

                        <Button x:Name="btnCheckout"
                                Height="50"
                                Background="{StaticResource AccentBrown}"
                                Foreground="White"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Content="ОПЛАТИТЬ"
                                IsEnabled="False"
                                Style="{StaticResource BasicButton3}">
                        </Button>

                        <Border Background="{StaticResource BeigeLight}"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Информация" 
                                           FontSize="12" 
                                           FontWeight="SemiBold" 
                                           Foreground="{StaticResource DeepBrown}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="Доставка рассчитывается после выбора способа получения" 
                                           FontSize="11" 
                                           Foreground="{StaticResource MediumBrown}"
                                           TextWrapping="Wrap"
                                           Opacity="0.8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>