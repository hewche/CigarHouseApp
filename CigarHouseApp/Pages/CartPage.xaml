<Page x:Class="CigarHouseApp.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="950"
      Background="#FAF7F2"
      Title="Корзина">

    <Page.Resources>
        <SolidColorBrush x:Key="DeepBrown" Color="#3E2A27"/>
        <SolidColorBrush x:Key="MediumBrown" Color="#6B4C3B"/>
        <SolidColorBrush x:Key="WarmBrown" Color="#8B5A4A"/>
        <SolidColorBrush x:Key="BeigeLight" Color="#F2E8DF"/>
        <SolidColorBrush x:Key="BeigeMedium" Color="#E8DDD2"/>
        <SolidColorBrush x:Key="AccentBrown" Color="#9B6B4A"/>
        <SolidColorBrush x:Key="TextLight" Color="#FAF7F2"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C2C2C"/>

        <!-- Стиль для карточки товара в корзине -->
        <Style x:Key="CartItemCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки количества -->
        <Style x:Key="QuantityButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="{StaticResource BeigeLight}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BeigeMedium}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource DeepBrown}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BeigeMedium}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrown}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки удаления -->
        <Style x:Key="RemoveButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE5E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для пустой корзины -->
        <Style x:Key="EmptyCartText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource MediumBrown}"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок страницы -->
            <Border Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Width="40" 
                                Height="40" 
                                Margin="0,0,15,0"
                                Cursor="Hand"
                                Style="{StaticResource RemoveButton}">
                            <Image Source="/Images/cigar_icon.png" Width="20" Height="20"/>
                        </Button>
                        <TextBlock Text="КОРЗИНА" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource DeepBrown}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{StaticResource AccentBrown}"
                                CornerRadius="15"
                                Padding="10,5"
                                Margin="15,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="tbItemsCount" 
                                       Text="0 товаров" 
                                       Foreground="White" 
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <Rectangle Height="2" 
                               Fill="{StaticResource BeigeMedium}" 
                               RadiusX="1" 
                               RadiusY="1"/>
                </StackPanel>
            </Border>

            <!-- Основной контент -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- Список товаров -->
                <Border Grid.Column="0" Margin="0,0,25,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="550">
                        <ItemsControl x:Name="itemsControlCart" ItemsSource="{Binding CartItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CartItemCard}">
                                        <Grid Margin="15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" 
                                                    Background="{StaticResource BeigeLight}"
                                                    CornerRadius="8"
                                                    Width="80"
                                                    Height="80">
                                                <Image Source="{Binding ProductImage}" 
                                                       Width="60" 
                                                       Height="60"
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" Margin="15,0">
                                                <TextBlock Text="{Binding ProductName}" 
                                                           FontSize="16" 
                                                           FontWeight="SemiBold" 
                                                           Foreground="{StaticResource DeepBrown}"
                                                           Margin="0,0,0,5"/>
                                                <TextBlock Text="{Binding Brand}" 
                                                           FontSize="12" 
                                                           Foreground="{StaticResource MediumBrown}"
                                                           Opacity="0.7"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <TextBlock Text="Цена: " 
                                                               FontSize="13" 
                                                               Foreground="{StaticResource TextDark}"
                                                               Opacity="0.6"/>
                                                    <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" 
                                                               FontSize="14" 
                                                               FontWeight="SemiBold" 
                                                               Foreground="{StaticResource AccentBrown}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" 
                                                        VerticalAlignment="Center" 
                                                        HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <Button Style="{StaticResource QuantityButton}" 
                                                            Tag="{Binding}">
                                                        <TextBlock Text="-" FontWeight="Bold"/>
                                                    </Button>
                                                    <TextBlock x:Name="tbQuantity" 
                                                               Text="{Binding Quantity}" 
                                                               Width="45" 
                                                               TextAlignment="Center"
                                                               FontSize="14" 
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                    <Button Style="{StaticResource QuantityButton}" 
                                                            Tag="{Binding}">
                                                        <TextBlock Text="+" FontWeight="Bold"/>
                                                    </Button>
                                                </StackPanel>
                                                <Button Style="{StaticResource RemoveButton}"
                                                        Tag="{Binding}"
                                                        HorizontalAlignment="Right">
                                                    <Image Source="/Images/trash_icon.png" Width="16" Height="16"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ItemsControl">
                                                        <Border Style="{StaticResource CartItemCard}" Padding="40">
                                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Image Source="/Images/empty_cart.png" 
                                                                       Width="120" 
                                                                       Height="120" 
                                                                       Opacity="0.5"
                                                                       Margin="0,0,0,20"/>
                                                                <TextBlock Text="Ваша корзина пуста" 
                                                                           FontSize="18" 
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource DeepBrown}"
                                                                           Margin="0,0,0,10"/>
                                                                <TextBlock Text="Добавьте товары из каталога" 
                                                                           Style="{StaticResource EmptyCartText}"/>
                                                                <Button Width="200"
                                                                        Height="45"
                                                                        Margin="0,30,0,0"
                                                                        Background="{StaticResource AccentBrown}"
                                                                        Foreground="White"
                                                                        FontSize="14"
                                                                        FontWeight="SemiBold"
                                                                        Cursor="Hand">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    CornerRadius="10">
                                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                                VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="{StaticResource WarmBrown}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="ПРОДОЛЖИТЬ ПОКУПКИ" Margin="0,0,10,0"/>
                                                                        <Image Source="/Images/shop_icon.png" Width="16" Height="16"/>
                                                                    </StackPanel>
                                                                </Button>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1" 
                        Background="White" 
                        CornerRadius="12"
                        Padding="20"
                        Height="Auto">
                    <StackPanel>
                        <TextBlock Text="ОФОРМЛЕНИЕ" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource DeepBrown}"
                                   Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Товары:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextDark}"
                                       Opacity="0.7"/>
                            <TextBlock x:Name="tbSubtotal" 
                                       Grid.Row="0" Grid.Column="1" 
                                       Text="0 ₽" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource DeepBrown}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                       Text="Доставка:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextDark}"
                                       Opacity="0.7"
                                       Margin="0,10,0,0"/>
                            <TextBlock x:Name="tbDelivery" 
                                       Grid.Row="1" Grid.Column="1" 
                                       Text="0 ₽" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource DeepBrown}"
                                       Margin="0,10,0,0"/>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BeigeMedium}" Margin="0,5,0,15"/>

                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="ИТОГО:" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource DeepBrown}"/>
                            <TextBlock x:Name="tbTotal" 
                                       Grid.Column="1" 
                                       Text="0 ₽" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource AccentBrown}"/>
                        </Grid>

                        <Button x:Name="btnCheckout"
                                Height="50"
                                Background="{StaticResource AccentBrown}"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource WarmBrown}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="{StaticResource BeigeMedium}"/>
                                            <Setter Property="Foreground" Value="{StaticResource MediumBrown}"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ОФОРМИТЬ ЗАКАЗ" Margin="0,0,10,0"/>
                                <Image Source="/Images/cigar_icon.png" Width="18" Height="18"/>
                            </StackPanel>
                        </Button>

                        <Border Background="{StaticResource BeigeLight}"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="ℹ️ Информация" 
                                           FontSize="12" 
                                           FontWeight="SemiBold" 
                                           Foreground="{StaticResource DeepBrown}"
                                           Margin="0,0,0,5"/>
                                <TextBlock Text="Доставка рассчитывается после выбора способа получения" 
                                           FontSize="11" 
                                           Foreground="{StaticResource MediumBrown}"
                                           TextWrapping="Wrap"
                                           Opacity="0.8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>