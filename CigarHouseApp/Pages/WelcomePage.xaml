<Page x:Class="CigarHouseApp.Pages.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="WelcomePage"
      Background="{StaticResource BeigeLight}">

    <Grid>
        <Border Width="700"
                MaxWidth="700"
                Padding="40"
                Background="White"
                CornerRadius="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Добро пожаловать в Cigar House"
                           FontSize="34"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="{StaticResource DeepBrown}"/>

                <TextBlock Margin="0,14,0,0"
                           Text="Премиальные сигары и аксессуары в одном месте."
                           FontSize="16"
                           TextAlignment="Center"
                           Foreground="{StaticResource MediumBrown}"/>

                <Border Margin="0,28,0,0"
                        Padding="18"
                        CornerRadius="10"
                        Background="{StaticResource BeigeLight}">
                    <TextBlock Text="Выберите раздел в верхнем меню, чтобы перейти к каталогу, заказам или избранному."
                               FontSize="14"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource WarmBrown}"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>
