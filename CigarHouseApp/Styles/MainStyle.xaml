<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PrimaryButtonKey" TargetType="Button">
        <Setter Property="Background" Value="#47352B"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style x:Key="PrimarySlider" TargetType="Slider">
        <Setter Property="BorderBrush" Value="AntiqueWhite"/>
        <Setter Property="Foreground" Value="Azure"/>
    </Style>
    <Style x:Key="PrimaryTextBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="B612 Mono"/>
    </Style>
    <Style x:Key="PrimaryListBlock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="B612 Mono"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    <Style x:Key="PrimaryProfileButton" TargetType="Ellipse">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter 
                Property="Fill" 
                Value="#CE9E6E"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>